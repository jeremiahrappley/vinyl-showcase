---
import Base from "../layouts/Base.astro";
import Cover from "../components/Cover.astro";
import { getWantlist } from "../lib/view-model.ts";

const wants = getWantlist();
---

<Base title="Wantlist">
	<div class="grid-header">
		<h1>Wantlist</h1>
		<p class="count">{wants.length} record{wants.length === 1 ? "" : "s"}</p>
	</div>

	{
		wants.length === 0 ? (
			<p class="empty">Nothing on the wantlist, or it hasn't been synced yet.</p>
		) : (
			<ul class="grid">
				{wants.map((w) => (
					<li>
						<a href={w.discogsUrl} target="_blank" rel="noopener">
							<Cover cover={w.cover} size="grid" alt={w.title} />
							<p class="title">{w.title}</p>
							<p class="meta">
								{w.artists} · {w.year}
							</p>
						</a>
					</li>
				))}
			</ul>
		)
	}
</Base>

<style>
	.grid-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.count {
		color: var(--text-dim);
		font-size: 0.9rem;
	}

	.empty {
		color: var(--text-dim);
	}

	.grid {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
		gap: 2rem 1.5rem;
		padding: 0;
		margin: 0;
	}

	.grid li a {
		display: block;
		text-decoration: none;
		color: var(--text);
	}

	.title {
		margin: 0.75rem 0 0.15rem;
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.meta {
		margin: 0;
		font-size: 0.82rem;
		color: var(--text-dim);
	}
</style>
