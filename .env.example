# Copy to .env and fill in. Never commit .env — it's gitignored.
#
# Get a personal access token at https://www.discogs.com/settings/developers
# (this is a plain PAT, not OAuth key+secret — the PAT authenticates as a
# user and unlocks private collection fields + authenticated image fetching)
DISCOGS_TOKEN=
DISCOGS_USERNAME=

# Discogs throttles generic User-Agents more aggressively than the
# documented rate limit. Make this unique to your instance.
DISCOGS_UA="VinylShowcase/1.0 +https://vinyl.jrappley.com"
